# Hieroglyph NLP Pipeline Configuration
# Copy this file to .env and modify as needed

# Flask Settings
FLASK_ENV=production
FLASK_DEBUG=False
FLASK_HOST=127.0.0.1
FLASK_PORT=5000

# Data Paths (relative to project root)
GARDINER_CSV=Test/Data/Update_gardiner_sign.csv
DICTIONARY_CSV=Test/Data/egyptian_dictionary.csv
INTENTION_CSV=Test/Data/intention_dataset.csv

# Model Settings
SPACY_MODEL=en_core_web_sm
TRANSLATION_MODEL=facebook/nllb-200-distilled-600M
SENTIMENT_MODEL=cardiffnlp/twitter-roberta-base-sentiment

# Performance
USE_GPU=False
CACHE_MODELS=True
DEFAULT_MAX_LENGTH=128
